# Git ignore rules for HVAC Technician Copilot

# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ----- Virtual Environments -----
venv/
.venv/
env/
ENV/

# ----- Environment Secrets -----
.env
.env.local
.env.*.local

# ----- Data (large files & generated artifacts) -----
# Raw PDFs — too large for git; share via Google Drive / S3
data/raw_pdfs/
# ChromaDB database — generated by Member 2, too large
data/chroma_db/

# chunks.json CAN be committed (it's the team handoff artifact)
# but comment this out if it's too large (> 50MB)
# data/chunks/chunks.json

# ----- Node / Frontend -----
node_modules/
.next/
out/
dist/
.cache/
frontend/.env
frontend/.env.local

# ----- IDE / OS -----
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ----- Testing & Coverage -----
.pytest_cache/
htmlcov/
.coverage
*.cover

# ----- Logs -----
*.log
logs/
