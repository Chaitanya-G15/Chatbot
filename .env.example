# ============================================================
# HVAC Technician Copilot — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to git (it's in .gitignore)

# ---- Member 1: Pipeline Config ----
# Path to the folder containing HVAC PDF manuals
PDF_INPUT_DIR=data/raw_pdfs

# Path where processed chunks will be saved
CHUNKS_OUTPUT_DIR=data/chunks

# ---- Member 2: Embedding Config ----
# Google Generative AI API key (for embeddings + LLM)
GOOGLE_API_KEY=your_google_api_key_here

# Embedding model to use
# Options: "models/text-embedding-004" or "all-MiniLM-L6-v2" (local)
EMBEDDING_MODEL=models/text-embedding-004

# ---- Member 2: Vector DB Config ----
# Path for persistent ChromaDB storage
CHROMA_DB_DIR=data/chroma_db

# ChromaDB collection name
CHROMA_COLLECTION=hvac_manuals

# ---- Member 3: Backend Config ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# LLM model for answer generation
LLM_MODEL=gemini-2.0-flash

# Number of top chunks to retrieve
TOP_K_RESULTS=5

# ---- Member 4: Frontend Config ----
VITE_API_BASE_URL=http://localhost:8000
